# Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ─── Supabase ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJ_your_service_role_key_here

# Vite client-side copies (must match above)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ─── Razorpay ───
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your_secret_here

# ─── Rate Limiting (optional — sensible defaults used if omitted) ───
# Auth routes: per-IP limits (15-min window)
# RATE_LIMIT_AUTH_IP_MAX=10
# Auth routes: per-account limits (15-min window)
# RATE_LIMIT_AUTH_ACCOUNT_MAX=5
# Auth routes: exponential backoff base (seconds)
# RATE_LIMIT_AUTH_BACKOFF_BASE=2
# Public endpoints: per-IP per-minute
# RATE_LIMIT_PUBLIC_IP_MAX=60
# Authenticated user actions: per-IP per-minute
# RATE_LIMIT_AUTH_USER_MAX=120
